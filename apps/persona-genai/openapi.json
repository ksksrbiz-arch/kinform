{
  "components": {
    "schemas": {
      "ApprovalRequest": {
        "properties": {
          "approver": {
            "maxLength": 200,
            "minLength": 3,
            "title": "Approver",
            "type": "string"
          }
        },
        "required": [
          "approver"
        ],
        "title": "ApprovalRequest",
        "type": "object"
      },
      "CreateDraftRequest": {
        "properties": {
          "channel": {
            "default": "instagram",
            "enum": [
              "instagram",
              "tiktok",
              "email",
              "print",
              "other"
            ],
            "title": "Channel",
            "type": "string"
          },
          "drop_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Drop Id"
          },
          "slug": {
            "maxLength": 64,
            "minLength": 3,
            "title": "Slug",
            "type": "string"
          }
        },
        "required": [
          "slug"
        ],
        "title": "CreateDraftRequest",
        "type": "object"
      },
      "DraftBlock": {
        "properties": {
          "content": {
            "title": "Content",
            "type": "string"
          },
          "ctas": {
            "items": {
              "type": "string"
            },
            "title": "Ctas",
            "type": "array"
          },
          "hashtags": {
            "items": {
              "type": "string"
            },
            "title": "Hashtags",
            "type": "array"
          },
          "title": {
            "title": "Title",
            "type": "string"
          },
          "tone": {
            "title": "Tone",
            "type": "string"
          }
        },
        "required": [
          "title",
          "content",
          "ctas",
          "hashtags",
          "tone"
        ],
        "title": "DraftBlock",
        "type": "object"
      },
      "GenerateRequest": {
        "properties": {
          "channel": {
            "default": "instagram",
            "enum": [
              "instagram",
              "tiktok",
              "email",
              "print",
              "other"
            ],
            "title": "Channel",
            "type": "string"
          },
          "days": {
            "default": 14,
            "maximum": 365.0,
            "minimum": 1.0,
            "title": "Days",
            "type": "integer"
          },
          "dropId": {
            "title": "Dropid",
            "type": "string"
          },
          "forceRegenerate": {
            "default": false,
            "title": "Forceregenerate",
            "type": "boolean"
          }
        },
        "required": [
          "dropId"
        ],
        "title": "GenerateRequest",
        "type": "object"
      },
      "GenerateResponse": {
        "properties": {
          "campaign": {
            "additionalProperties": true,
            "title": "Campaign",
            "type": "object"
          },
          "campaignId": {
            "title": "Campaignid",
            "type": "string"
          },
          "draft": {
            "$ref": "#/components/schemas/DraftBlock"
          },
          "simulationId": {
            "title": "Simulationid",
            "type": "string"
          },
          "status": {
            "title": "Status",
            "type": "string"
          },
          "validation": {
            "$ref": "#/components/schemas/ValidationBlock"
          }
        },
        "required": [
          "simulationId",
          "campaignId",
          "status",
          "draft",
          "validation",
          "campaign"
        ],
        "title": "GenerateResponse",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "RejectRequest": {
        "properties": {
          "reason": {
            "maxLength": 500,
            "minLength": 1,
            "title": "Reason",
            "type": "string"
          }
        },
        "required": [
          "reason"
        ],
        "title": "RejectRequest",
        "type": "object"
      },
      "SimulateRequest": {
        "properties": {
          "seed": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Seed"
          }
        },
        "title": "SimulateRequest",
        "type": "object"
      },
      "ValidationBlock": {
        "properties": {
          "errors": {
            "items": {
              "type": "string"
            },
            "title": "Errors",
            "type": "array"
          },
          "passed": {
            "title": "Passed",
            "type": "boolean"
          }
        },
        "required": [
          "passed",
          "errors"
        ],
        "title": "ValidationBlock",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
  "info": {
    "description": "Governed multi-agent campaign service for KINFORM-AEO.",
    "title": "KINFORM PersonaGenAI",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
