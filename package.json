{
  "name": "kinform-aeo",
  "version": "0.1.0",
  "private": true,
  "description": "KINFORM Autonomous Ecosystem Orchestrator (KINFORM-AEO) — monorepo containing the storefront, Payload Studio IDE, PersonaGenAI agentic service, Torqued Graph data layer, and governance pipeline.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "dev": "turbo run dev",
    "clean": "turbo run clean && rm -rf .turbo node_modules/.cache",
    "storefront:dev": "turbo run dev --filter=@kinform/storefront",
    "storefront:build": "turbo run build --filter=@kinform/storefront",
    "studio:dev": "turbo run dev --filter=@kinform/payload-studio",
    "studio:build": "turbo run build --filter=@kinform/payload-studio",
    "db:generate": "turbo run db:generate --filter=@kinform/torqued-graph",
    "db:migrate": "turbo run db:migrate --filter=@kinform/torqued-graph",
    "db:migrate:deploy": "turbo run db:migrate:deploy --filter=@kinform/torqued-graph",
    "db:seed": "turbo run seed --filter=@kinform/torqued-graph",
    "db:studio": "npm run prisma:studio --workspace @kinform/torqued-graph",
    "persona:dev": "cd apps/persona-genai && uvicorn kinform_persona.app:app --reload --port 8088",
    "persona:test": "cd apps/persona-genai && python -m pytest -q",
    "governance:check": "node infra/github-actions/scripts/governance-check.mjs"
  },
  "devDependencies": {
    "turbo": "^2.3.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "license": "UNLICENSED",
  "packageManager": "npm@11.9.0"
}
