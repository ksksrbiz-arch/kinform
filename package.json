{
  "name": "kinform-aeo",
  "version": "0.1.0",
  "private": true,
  "description": "KINFORM Autonomous Ecosystem Orchestrator (KINFORM-AEO) — monorepo containing the storefront, Payload Studio IDE, PersonaGenAI agentic service, Torqued Graph data layer, and governance pipeline.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "storefront:dev": "npm run dev --workspace apps/storefront",
    "storefront:build": "npm run build --workspace apps/storefront",
    "studio:dev": "npm run dev --workspace apps/payload-studio",
    "studio:build": "npm run build --workspace apps/payload-studio",
    "graph:generate": "npm run prisma:generate --workspace packages/torqued-graph",
    "graph:migrate": "npm run prisma:migrate --workspace packages/torqued-graph",
    "graph:seed": "npm run seed --workspace packages/torqued-graph",
    "shared:build": "npm run build --workspace packages/shared",
    "persona:dev": "cd apps/persona-genai && uvicorn kinform_persona.app:app --reload --port 8088",
    "persona:test": "cd apps/persona-genai && python -m pytest -q",
    "governance:check": "node infra/github-actions/scripts/governance-check.mjs",
    "lint": "npm run lint --workspaces --if-present",
    "build": "npm run build --workspaces --if-present"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "license": "UNLICENSED"
}
