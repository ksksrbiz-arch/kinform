{
  "name": "@kinform/torqued-graph",
  "version": "0.1.0",
  "private": true,
  "description": "KINFORM Torqued Graph — Prisma schema (canonical) + SQLAlchemy mirror + shared TypeScript types for the physical-to-digital affiliate revenue graph.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "default": "./src/client.ts"
    }
  },
  "scripts": {
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev --name init",
    "db:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "use:sqlite": "node scripts/switch-provider.mjs sqlite",
    "use:postgres": "node scripts/switch-provider.mjs postgresql",
    "seed": "tsx prisma/seed.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
