# =============================================================================
# KINFORM-AEO — environment template
# Copy to `.env` (root) or per-app `.env.local` files. Never commit real values.
# =============================================================================

# -----------------------------------------------------------------------------
# Torqued Graph (Prisma + SQLAlchemy)
# -----------------------------------------------------------------------------
# Default: local SQLite for zero-config dev. Switch to Postgres for staging/prod.
#   Postgres example: postgresql://kinform:kinform@localhost:5432/kinform
DATABASE_URL="file:./packages/torqued-graph/prisma/dev.db"

# -----------------------------------------------------------------------------
# PersonaGenAI (FastAPI + LangGraph)
# -----------------------------------------------------------------------------
# Provider selection. `stub` is the deterministic local LLM that ships by default.
# Swap to `openai` or `anthropic` when ready (and provide the matching key).
KINFORM_LLM_PROVIDER="stub"
# OPENAI_API_KEY=""
# ANTHROPIC_API_KEY=""

# Service binding
PERSONA_GENAI_HOST="0.0.0.0"
PERSONA_GENAI_PORT="8088"

# Governance — operator email used as the default human approver identity.
KINFORM_DEFAULT_APPROVER="founder@kinform.local"

# -----------------------------------------------------------------------------
# Payload Studio (Next.js IDE)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_PERSONA_GENAI_URL="http://localhost:8088"
NEXT_PUBLIC_KINFORM_BRAND_NAME="KINFORM"

# -----------------------------------------------------------------------------
# Storefront (existing site — unchanged)
# -----------------------------------------------------------------------------
# POSTGRES_URL=""
# RESEND_API_KEY=""
